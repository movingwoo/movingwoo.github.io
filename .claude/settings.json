{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*_rsa)",
      "Read(**/*_rsa.pub)",
      "Read(**/id_rsa*)",
      "Read(**/*credentials*)",
      "Read(**/secrets/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*_rsa)",
      "Edit(**/*credentials*)",
      "Edit(**/secrets/**)",
      "Read(_site/**)",
      "Read(.jekyll-cache/**)",
      "Read(vendor/**)",
      "Read(node_modules/**)",
      "Read(.git/**)"
    ],
    "allow": [
      "Bash(bundle exec *)",
      "Bash(bundle install)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(command -v node)",
      "Bash(command -v ruby)",
      "Skill(run)",
      "Bash(npm ls *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(grep *)",
      "Bash(pkill -f \"jekyll serve\")",
      "Read(//tmp/**)"
    ]
  }
}
